VITE_API_BASE_URL=http://localhost:8000

# Optional. Pre-fills the Admin/Product & CX login tabs with these dev
# credentials so you don't have to type them every time - purely a local
# convenience, never sent anywhere but the login form's own fields. Should
# match the backend's SUPER_ADMIN_EMAIL/SUPER_ADMIN_PASSWORD and
# PRODUCT_CX_EMAIL/PRODUCT_CX_PASSWORD (see ../.env.example), which is what
# actually seeds these accounts into the database on backend startup (see
# backend/seed.py). Leave unset to get plain empty login forms.
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=admin@example.com
VITE_PRODUCT_CX_EMAIL=productcx@example.com
VITE_PRODUCT_CX_PASSWORD=productcx@example.com
