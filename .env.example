# ==========================================================
# Smart Support Ticket Router - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit a real .env file or real API keys.
# ==========================================================

# OpenAI is the default provider - tried first on every request.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq is the backup provider. Only used if OpenAI is unavailable (no key,
# rate limit, outage, etc.) - see ticket_router/ai/combined_provider.py.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional. Comma-separated list of Groq models to try, in order, if
# GROQ_MODEL fails (rate limit, timeout, decommissioned model, etc.).
# Leave unset to use the built-in default chain (see
# ticket_router/ai/groq_provider.py).
# GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,meta-llama/llama-4-scout-17b-16e-instruct,openai/gpt-oss-120b
