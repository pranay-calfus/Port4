OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional. Comma-separated list of other OpenAI models to try, in order, if
# OPENAI_MODEL fails (rate limit, timeout, decommissioned model, etc.).
# Fallback is opt-in - leave unset and OPENAI_MODEL is the only model tried,
# with no fallback on failure. Good options to list here:
#   gpt-4o             - strong general-purpose model, solid function-calling
#   gpt-4o-mini        - fast and cheap, good default for classification tasks
#   gpt-4-turbo        - previous-gen flagship, reliable fallback
#   gpt-3.5-turbo      - cheapest/fastest, last resort in the chain
# OPENAI_FALLBACK_MODELS=gpt-4o,gpt-4-turbo,gpt-3.5-turbo

# Optional. Path to the SQLite database file used to persist routed tickets
# and teams. Leave unset to default to an absolute <repo>/tickets.db path,
# which is immune to which directory `streamlit run` happens to be launched
# from. Only set this if you want the database stored somewhere else.
# TICKET_DB_PATH=/absolute/path/to/tickets.db

# Shared password for the admin dashboard (pages/Admin_Dashboard.py). Required
# to unlock the dashboard - it stays inaccessible if this is left empty.
ADMIN_PASSWORD=
