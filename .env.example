OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional. Comma-separated list of other OpenAI models to try, in order, if
# OPENAI_MODEL fails (rate limit, timeout, decommissioned model, etc.).
# Fallback is opt-in - leave unset and OPENAI_MODEL is the only model tried,
# with no fallback on failure. Good options to list here:
#   gpt-4o             - strong general-purpose model, solid function-calling
#   gpt-4o-mini        - fast and cheap, good default for classification tasks
#   gpt-4-turbo        - previous-gen flagship, reliable fallback
#   gpt-3.5-turbo      - cheapest/fastest, last resort in the chain
# OPENAI_FALLBACK_MODELS=gpt-4o,gpt-4-turbo,gpt-3.5-turbo

# Optional. SQLAlchemy database URL for the backend API (users, tickets,
# ticket_messages, ticket_activity - see backend/models.py). Leave unset to
# default to an absolute <repo>/port4.db SQLite file. Point this at a
# Postgres URL (e.g. postgresql+psycopg://user:pass@host/dbname) to switch
# databases with no code changes.
# DATABASE_URL=sqlite:////absolute/path/to/port4.db

# Secret key used to sign JWT access tokens issued by backend/auth.py.
# REQUIRED in any non-local deployment - the backend refuses to start with
# the insecure default outside local dev. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=insecure-dev-secret-change-me-32bytes+

# Optional. Minutes until an issued JWT access token expires.
# JWT_EXPIRE_MINUTES=1440

# There is no self-service admin registration by design (see
# "Admin login should NOT be accessible through the normal user interface").
# Create the first admin account with:
#   python -m backend.create_admin --name "Ops Admin" --email admin@example.com --password <pw>
# Add --department "Engineering" (etc.) to scope an admin to one team instead
# of a super-admin who sees every team's tickets.
