OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional. Comma-separated list of other OpenAI models to try, in order, if
# OPENAI_MODEL fails (rate limit, timeout, decommissioned model, etc.).
# Fallback is opt-in - leave unset and OPENAI_MODEL is the only model tried,
# with no fallback on failure. Good options to list here:
#   gpt-4o             - strong general-purpose model, solid function-calling
#   gpt-4o-mini        - fast and cheap, good default for classification tasks
#   gpt-4-turbo        - previous-gen flagship, reliable fallback
#   gpt-3.5-turbo      - cheapest/fastest, last resort in the chain
# OPENAI_FALLBACK_MODELS=gpt-4o,gpt-4-turbo,gpt-3.5-turbo

# Required. Supabase project URL and secret (service_role) key - the app's
# only runtime connection to the database (users, tickets, ticket_messages,
# ticket_activity), via backend/supabase_client.py. Find both under
# Supabase -> Project Settings -> API. Use the SECRET key, not the
# publishable/anon key - the backend is a trusted server with no
# Row-Level Security policies in place, so it needs unrestricted access.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SECRET_KEY=sb_secret_[rest-of-your-secret-key]

# Required. Raw Postgres connection to the same Supabase project, used only
# by Alembic (see backend/db.py: run_migrations(), which runs
# `alembic upgrade head` on every app startup) and the test suite's
# table-truncation fixture (tests/backend/conftest.py) - the app itself
# never opens its own database connection, it goes through the Supabase
# client above. Find this under Supabase -> Project Settings -> Database ->
# Connection string. Prefer the direct connection if your network has
# IPv6; otherwise use the session-mode pooler (shown below) - the
# transaction-mode pooler can't run all DDL.
DIRECT_URL=postgresql+psycopg://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Secret key used to sign JWT access tokens issued by backend/auth.py.
# REQUIRED in any non-local deployment - the backend refuses to start with
# the insecure default outside local dev. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=insecure-dev-secret-change-me-32bytes+

# Optional. Minutes until an issued JWT access token expires.
# JWT_EXPIRE_MINUTES=1440

# Optional. Comma-separated list of origins allowed to call this API (CORS).
# Defaults to the React frontend's Vite dev server origin.
# CORS_ORIGINS=http://localhost:5173

# There is no self-service admin registration by design (see
# "Admin login should NOT be accessible through the normal user interface").
# Create the first admin account with:
#   python -m backend.create_admin --name "Ops Admin" --email admin@example.com --password <pw>
# Add --department "Engineering" (etc.) to scope an admin to one team instead
# of a super-admin who sees every team's tickets.
