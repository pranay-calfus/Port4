# --- Backend (backend/.env) ---
PORT=5000
NODE_ENV=development

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Frontend (frontend/.env) ---
VITE_API_BASE_URL=http://localhost:5000/api
