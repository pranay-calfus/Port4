# ==========================================================
# Smart Support Ticket Router - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit a real .env file or real API keys.
# ==========================================================

# OpenAI is the only AI provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional. Comma-separated list of other OpenAI models to try, in order, if
# OPENAI_MODEL fails (rate limit, timeout, decommissioned model, etc.).
# Leave unset to use the built-in default chain (see
# ticket_router/ai/openai_provider.py).
# OPENAI_FALLBACK_MODELS=gpt-4o,gpt-4-turbo,gpt-3.5-turbo

# Optional. Postgres connection string used to persist routed tickets (see
# ticket_router/db.py). Leave unset to use the default below; persistence is
# best-effort, so the app still works if Postgres isn't running.
# DATABASE_URL=postgresql://ticket_router:ticket_router@localhost:5432/ticket_router
